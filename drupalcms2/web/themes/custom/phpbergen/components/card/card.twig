{% set card_color = color|default('neutral') %}
{% set card_variant = variant|default('default') %}
{% set card_size = size|default('md') %}
{% set heading_level = level|default(3) %}
{% set is_clickable = url is not empty %}

{% set card_attrs %}
  class="ds-card{{ card_classes ? ' ' ~ card_classes : '' }}"
  data-color="{{ card_color }}"
  data-variant="{{ card_variant }}"
  data-size="{{ card_size }}"
{% endset %}

{% if is_clickable %}
  <a {{ card_attrs }} href="{{ url }}">
{% else %}
  <div {{ card_attrs }}>
{% endif %}

  {% if media.src is not empty %}
    <div class="ds-card__block">
      {% block media %}
        {% include 'canvas:image' ignore missing with {
          src: media.src,
          alt: media.alt,
          width: media.width,
          height: media.height,
        } only %}
      {% endblock %}
    </div>
  {% endif %}

  <div class="ds-card__block">
    {% if heading_level == 2 %}
      <h2>{{ heading_text }}</h2>
    {% elseif heading_level == 4 %}
      <h4>{{ heading_text }}</h4>
    {% elseif heading_level == 5 %}
      <h5>{{ heading_text }}</h5>
    {% else %}
      <h3>{{ heading_text }}</h3>
    {% endif %}

    {% if text is not empty %}
      <p>{{ text }}</p>
    {% endif %}
  </div>

{% if is_clickable %}
  </a>
{% else %}
  </div>
{% endif %}
